# ─── Dependencies ────────────────────────────────────────────
node_modules/

# ─── Build outputs ───────────────────────────────────────────
dist/
build/
out/

# ─── Environment & secrets ───────────────────────────────────
.env
.env.local
.env.*.local
.dev.vars          # Wrangler local secret vars (never commit)

# ─── Wrangler / Cloudflare Workers ───────────────────────────
.wrangler/         # Local D1, KV state managed by Wrangler
wrangler.toml.bak

# ─── Logs ────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── OS & editor noise ───────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.vscode/settings.json
.idea/

# ─── TypeScript cache ────────────────────────────────────────
*.tsbuildinfo

# ─── Misc ────────────────────────────────────────────────────
*.local
.cache/
